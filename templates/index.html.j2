{# ── SECTION D — IMPORT RECORDS JS ──────────────────────────────────── #}
<script>
(function () {
  'use strict';

  /* ── Show more (90 days) / show fewer ───────────────────────────────── */
  var visibleCount = 3;

  function getRows() {
    var tbody = document.getElementById('import-records-tbody');
    return tbody ? Array.prototype.slice.call(tbody.querySelectorAll('tr.import-row')) : [];
  }

  function updateButtons(expanded) {
    var showMore  = document.getElementById('show-more-btn');
    var showFewer = document.getElementById('show-fewer-btn');
    if (!showMore || !showFewer) return;
    showMore.style.display  = expanded ? 'none' : '';
    showFewer.style.display = expanded ? '' : 'none';
  }

  window.importShowMore = function () {
    /* Show only rows within the last 90 days */
    var cutoff = new Date();
    cutoff.setDate(cutoff.getDate() - 90);
    var rows = getRows();
    var anyShown = false;
    rows.forEach(function (r, i) {
      if (i < visibleCount) return; /* already visible */
      var dateStr = r.getAttribute('data-date');
      var d = dateStr ? new Date(dateStr) : null;
      if (d && !isNaN(d.getTime()) && d >= cutoff) {
        r.style.display = '';
        anyShown = true;
      }
    });
    updateButtons(true);
    checkOverflow();
  };

  window.importShowFewer = function () {
    var rows = getRows();
    rows.forEach(function (r, i) {
      r.style.display = i < visibleCount ? '' : 'none';
    });
    updateButtons(false);
    /* Scroll to table top without jumping to page top */
    var wrapper = document.getElementById('import-table-wrapper');
    if (wrapper) wrapper.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  };

  /* Scroll hint — add .is-overflowing if table wider than wrapper */
  function checkOverflow() {
    var wrapper = document.getElementById('import-table-wrapper');
    if (!wrapper) return;
    var table = wrapper.querySelector('table');
    if (!table) return;
    wrapper.classList.toggle('is-overflowing', table.scrollWidth > wrapper.clientWidth);
  }

  window.addEventListener('resize', checkOverflow);
  checkOverflow();

  /* ── CSV email flow ──────────────────────────────────────────────────── */
  /* ponytail: Google Apps Script endpoint injected at build time via csv_endpoint_url.
     mode: 'no-cors' — Apps Script does not support OPTIONS preflight;
     opaque response is always treated as success. C8-P2. */
  var CSV_ENDPOINT = '{{ csv_endpoint_url }}';

  window.csvShowForm = function () {
    var btn  = document.getElementById('csv-request-btn');
    var form = document.getElementById('csv-email-form');
    if (btn)  btn.style.display  = 'none';
    if (form) form.classList.add('is-visible');
  };

  window.csvCancel = function () {
    var btn   = document.getElementById('csv-request-btn');
    var form  = document.getElementById('csv-email-form');
    var error = document.getElementById('csv-error');
    if (btn)   btn.style.display = '';
    if (form)  form.classList.remove('is-visible');
    if (error) error.classList.remove('is-visible');
    var input = document.getElementById('csv-email-input');
    if (input) input.value = '';
  };

  window.csvSubmit = function () {
    var input  = document.getElementById('csv-email-input');
    var form   = document.getElementById('csv-email-form');
    var conf   = document.getElementById('csv-confirmation');
    var errEl  = document.getElementById('csv-error');
    var btn    = document.getElementById('csv-request-btn');
    if (!input || !input.checkValidity()) {
      input.reportValidity();
      return;
    }

    var email = input.value.trim();

    fetch(CSV_ENDPOINT || '/api/csv-request', {
      method: 'POST',
      mode: 'no-cors',
      headers: { 'Content-Type': 'text/plain' },
      body: JSON.stringify({
        email_address:  email,
        request_source: 'vkh_import_records'
      })
    })
    .then(function () {
      /* no-cors = opaque response; always treat as success */
      if (form)  form.classList.remove('is-visible');
      if (errEl) errEl.classList.remove('is-visible');
      if (conf) {
        conf.textContent = 'CSV file sent to ' + email + '. Check your inbox within a few minutes.';
        conf.classList.add('is-visible');
      }
      /* After 6 seconds: hide confirmation, restore button */
      setTimeout(function () {
        if (conf) conf.classList.remove('is-visible');
        if (btn)  btn.style.display = '';
        if (input) input.value = '';
      }, 6000);
    })
    .catch(function () {
      /* Error: show inline error, keep form visible */
      if (errEl) errEl.classList.add('is-visible');
    });
  };

}());
</script>

</body>
</html>
