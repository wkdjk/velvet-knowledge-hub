<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Velvet Knowledge Hub — Korea deer velvet trade intelligence</title>
  <link rel="stylesheet" href="assets/style.css">
</head>
<body>

{# ── HEADER ─────────────────────────────────────────────────────────────── #}
<header>
  <div class="page-wrapper">
    <h1>Velvet Knowledge Hub</h1>
    <p class="tagline">Korea deer velvet market intelligence for the New Zealand deer industry</p>
    <p class="last-built caption">Last built: {{ meta.last_built_utc | default(build_date) | default("—") }}</p>
  </div>
</header>

{# ── KPI STRIP ────────────────────────────────────────────────────────── #}
{# Source: meta object built by build.py from cross-section data           #}
<div class="page-wrapper">
  <div class="kpi-strip">

    {# KPI 1: NZ exports rolling 12-month in tonnes — A-1 #}
    <div class="kpi-card">
      <p class="kpi-label">NZ EXPORTS (ROLLING 12-MONTH)</p>
      {% if kpi is defined and kpi.nz_export_latest is defined and kpi.nz_export_latest != "—" %}
        <p class="kpi-value">{{ kpi.nz_export_latest }}</p>
        {% if kpi.nz_export_delta is defined and kpi.nz_export_delta != "—" %}
          <p class="delta-indicator">{{ kpi.nz_export_delta }}</p>
        {% endif %}
        <p class="delta-indicator delta-neutral">tonnes dried-equivalent — Stats NZ</p>
      {% else %}
        <p class="kpi-value text-muted">—</p>
      {% endif %}
    </div>

    {# KPI 2: News articles past 90 days — C-5e: renamed articles_30d → articles_90d, window 30d → 90d, sub-label added #}
    <div class="kpi-card">
      <p class="kpi-label">NEWS ARTICLES (LAST 90 DAYS)</p>
      {% if kpi is defined and kpi.articles_90d is defined and kpi.articles_90d != "—" %}
        <p class="kpi-value">{{ kpi.articles_90d }}</p>
        <p class="delta-indicator delta-neutral">relevant articles — Naver + Google News</p>
      {% else %}
        <p class="kpi-value text-muted">—</p>
      {% endif %}
    </div>

    {# KPI 3: Food imports last 90 days — OI-1 (window extended 30d → 90d to align with news pulse) #}
    <div class="kpi-card">
      <p class="kpi-label">FOOD IMPORTS (LAST 90 DAYS)</p>
      {% if kpi is defined and kpi.food_imports_90d is defined and kpi.food_imports_90d != "—" %}
        <p class="kpi-value">{{ kpi.food_imports_90d }}</p>
        <p class="delta-indicator delta-neutral">notifications — food channel (MFDS)</p>
      {% else %}
        <p class="kpi-value text-muted">—</p>
      {% endif %}
    </div>

  </div>{# /kpi-strip #}
</div>

{# ── NAVIGATION ───────────────────────────────────────────────────────── #}
<nav class="page-wrapper">
  <ul class="nav-list">
    <li><a href="#trade-flows">Trade flows</a></li>
    <li><a href="#import-intelligence">Import intelligence</a></li>
    <li><a href="#market-presence">Market presence</a></li>
    <li><a href="#news-pulse">News pulse</a></li>
  </ul>
</nav>

{# ── MAIN CONTENT ─────────────────────────────────────────────────────── #}
<main class="page-wrapper">

  {# ── SECTION: TRADE FLOWS (C-3e redesign) ────────────────────────── #}
  {# C-3c DesignQ spec / C-3d CommsQ copy / English-only (Commander decision) #}
  {% set trade_flows = sections.trade_flows if sections is defined and sections.trade_flows is defined else {} %}
  <section id="trade-flows">

    <div class="section-header">
      <div class="section-header-left">
        <h2>Trade flows</h2>
        <span class="last-updated">Last updated: {{ trade_flows.last_updated | default("—") }}</span>
      </div>
      {% if trade_flows.enabled and trade_flows.has_data %}
        <a class="download-btn" href="downloads/trade_flows.csv">Download CSV</a>
      {% endif %}
    </div>

    <p class="source-footnote">Sources: Stats NZ (NZ exports) · QIA (Korea quarantine) · KSTAT (Korea customs)</p>

    {% if trade_flows.enabled and trade_flows.has_data %}

      {# ── YoY KPI chip ────────────────────────────────────────────────── #}
      {% set chip = tf_yoy_chip | default({"label": "—", "direction": "neutral"}) %}
      <div class="trade-flows-kpi-chip" aria-label="Rolling year NZ exports year-on-year comparison">
        <span class="chip-label">Rolling year (Oct–Sep):</span>
        <span class="chip-source">NZ exports to Korea</span>
        {% if chip.direction == "up" %}
          <span class="chip-delta delta-positive">{{ chip.label }}</span>
        {% elif chip.direction == "down" %}
          <span class="chip-delta delta-negative">{{ chip.label }}</span>
        {% else %}
          <span class="chip-delta delta-neutral">{{ chip.label if chip.label != "—" else "No data selected" }}</span>
        {% endif %}
        <span class="chip-suffix">vs prior season</span>
      </div>

      {# ── Source toggle — pill checkboxes ─────────────────────────────── #}
      <div class="source-toggle" role="group" aria-label="Show or hide data sources">
        <div class="source-toggle__pill source-toggle__pill--nz">
          <input type="checkbox" id="toggle-nz" name="source" value="nz" checked>
          <label for="toggle-nz">NZ exports</label>
        </div>
        <div class="source-toggle__pill source-toggle__pill--qia">
          <input type="checkbox" id="toggle-qia" name="source" value="qia" checked>
          <label for="toggle-qia">Korea quarantine (QIA)</label>
        </div>
        <div class="source-toggle__pill source-toggle__pill--kstat">
          <input type="checkbox" id="toggle-kstat" name="source" value="kstat" checked>
          <label for="toggle-kstat">Korea customs (KSTAT)</label>
        </div>
      </div>

      {# ── Panel A — Volume chart ───────────────────────────────────────── #}
      <div class="chart-panel">
        <h3>Volume — monthly and rolling 12-month (dried-equivalent kg)</h3>
        <div class="chart-canvas-wrapper" style="height:320px;">
          <canvas id="chart-volume"
            aria-label="Monthly and rolling 12-month trade volume in dried-equivalent kg" role="img"></canvas>
        </div>
        <p class="chart-annotation">All volumes are shown as dried-equivalent kg. Conversion applied: fresh/frozen velvet × 0.33 = dried-equivalent kg. Dried velvet requires no conversion.</p>
      </div>

      {# Panel B (unit price chart) removed per Commander feedback F-06. #}

      {# ── Panel C — Export destination breakdown ──────────────────────── #}
      {# C-3h: NZ exports by destination. Stacked area (FOB NZD).           #}
      {# C2 pie removed per F-12. Panel B unit price removed per F-06.      #}
      <h3 class="section-subheading">Export destination breakdown</h3>

      {# C1 — Stacked area chart: NZD FOB by destination, all available dates #}
      <div class="chart-panel">
        <h3>NZ velvet exports by destination — FOB value (NZD)</h3>
        <div class="chart-canvas-wrapper" style="height:280px;">
          <canvas id="chart-destination-area"
            aria-label="NZ deer velvet exports by destination, stacked area chart of NZD FOB value" role="img"></canvas>
        </div>
        <p class="chart-annotation">Source: Stats NZ. All available months shown. Countries not individually listed are grouped as Other.</p>
      </div>

      {# C2 (pie chart — 2025 volume share) removed per Commander feedback F-12. #}

      {# ── Panel D — Korean market: imports by origin ───────────────────── #}
      {# C-3h: QIA quarantine data, grouped by country, latest 2 full years.  #}
      <h3 class="section-subheading">Korean market — imports by origin</h3>

      {% if tf_qia_by_origin and tf_qia_by_origin | length > 0 %}
        <div class="chart-panel">
          <h3>South Korean velvet imports by origin — QIA quarantine records (kg)</h3>
          <div class="chart-canvas-wrapper" style="height:300px;">
            <canvas id="chart-qia-origin"
              aria-label="South Korean deer velvet imports by country of origin, grouped bar chart" role="img"></canvas>
          </div>
          <p class="chart-annotation">Source: Animal and Plant Quarantine Agency (South Korea). Volumes shown as raw import kg as recorded at quarantine inspection. No dried-equivalent conversion applied.</p>
        </div>
      {% else %}
        <div class="placeholder-card">
          <p class="placeholder-title">Korean import origin data not yet available</p>
          <p class="placeholder-body">QIA quarantine data will appear here after the next scheduled ingest. Source: Animal and Plant Quarantine Agency (South Korea).</p>
        </div>
      {% endif %}

      {# ── Source discrepancy accordion ─────────────────────────────────── #}
      <details class="discrepancy-accordion">
        <summary class="discrepancy-accordion__trigger" aria-label="Why do the three sources show different volumes?">
          <span>ⓘ Why do the three sources show different volumes?</span>
          <span class="discrepancy-accordion__chevron" aria-hidden="true">&#9654;</span>
        </summary>
        <div class="discrepancy-accordion__body">
          <h4>Why the three sources show different volumes</h4>
          <p>NZ exports (Stats NZ) records shipments at the point of export from New Zealand.<br>
          Korea quarantine (QIA) records physical arrivals at Korean ports, inspected upon landing.<br>
          Korea customs (KSTAT) records formal customs declarations filed upon import clearance.</p>
          <p>Four factors cause the figures to differ:</p>
          <ol>
            <li><strong>Timing.</strong> Sea freight from New Zealand to Korea takes approximately two to three weeks. An NZ shipment recorded in October may appear in the QIA and KSTAT data in November.</li>
            <li><strong>Transit and re-export.</strong> New Zealand also exports velvet to China, Hong Kong, and Taiwan. Some of that product is subsequently re-exported to Korea and appears in QIA and KSTAT data without a matching NZ-to-Korea export record.</li>
            <li><strong>Classification codes.</strong> New Zealand and Korea both revised the official product codes used to classify deer velvet in 2022. Data recorded before and after that change may not align perfectly across the boundary.</li>
            <li><strong>Fresh/frozen versus dried weight.</strong> Korea quarantine (QIA) records fresh/frozen and dried velvet volumes separately. Korea customs (KSTAT) records a combined kg total. A standard conversion factor (0.33 kg dried = 1 kg fresh/frozen) is applied to make volumes comparable, but rounding and mixed shipments introduce small residual differences.</li>
          </ol>
          <p class="closing-note">These differences are not data errors. They reflect the different measurement points and classification systems of three independent agencies.</p>
        </div>
      </details>

    {% else %}
      <p class="source-footnote">Source: Stats NZ · QIA · KSTAT API</p>
      <div class="placeholder-card">
        <p class="placeholder-title">Trade flows data not yet available</p>
        <p class="placeholder-body">Data will appear here after the next scheduled build.</p>
      </div>
    {% endif %}

  </section>

  {# ── CHART.JS SCRIPT — trade flows + B-7 price (no CDN — bundled M-1) #}
  <script src="assets/chart.min.js"></script>
  {% if trade_flows.enabled and trade_flows.has_data %}
  <script>
  (function () {
    'use strict';

    /* ── Source colours (match CSS tokens) ──────────────────────────── */
    var C_NZ    = '#1A5276';
    var C_QIA   = '#7D6608';
    var C_KSTAT = '#6E2F0A';

    /* ── Embedded datasets (injected by build.py) ────────────────────── */
    var NZ    = {{ tf_nz_export    | tojson }};
    var QIA   = {{ tf_korea_qia    | tojson }};
    var KSTAT = {{ tf_korea_kstat  | tojson }};
    var HARVEST_BOUNDS = {{ tf_harvest_boundaries | tojson }};

    /* ── Chart.js shared defaults ────────────────────────────────────── */
    var FONT_FAMILY = '"Trebuchet MS", "Gill Sans MT", Arial, sans-serif';
    Chart.defaults.font.family = FONT_FAMILY;
    Chart.defaults.font.size   = 11;
    Chart.defaults.color       = '#444444';

    /* ── Helper: extract {x, y} arrays from source objects ──────────── */
    function xyFrom(arr) {
      return (arr || []).map(function (p) { return { x: p.x, y: p.y }; });
    }

    /* ── Build harvest-year background plugins (canvas afterDraw) ────── */
    /* Falls back from annotation plugin to custom afterDraw callback.    */
    var harvestPlugin = {
      id: 'harvestBands',
      afterDraw: function (chart) {
        if (!HARVEST_BOUNDS || !HARVEST_BOUNDS.length) return;
        var ctx  = chart.ctx;
        var xScale = chart.scales['x'];
        if (!xScale) return;
        var top    = chart.chartArea.top;
        var bottom = chart.chartArea.bottom;
        var labels = chart.data.labels || [];

        HARVEST_BOUNDS.forEach(function (oct, idx) {
          var octIdx = labels.indexOf(oct);
          if (octIdx < 0) return;

          /* Band: from left edge of October bar to left edge of November bar */
          var x0 = xScale.getPixelForValue(octIdx) - (xScale.getPixelForValue(1) - xScale.getPixelForValue(0)) / 2;
          var x1 = xScale.getPixelForValue(octIdx) + (xScale.getPixelForValue(1) - xScale.getPixelForValue(0)) / 2;

          ctx.save();
          ctx.fillStyle = 'rgba(167, 130, 48, 0.08)';
          ctx.fillRect(x0, top, x1 - x0, bottom - top);

          /* Label "Season start" only on the first (leftmost) October band */
          if (idx === 0) {
            ctx.fillStyle = '#777777';
            ctx.font      = '9px ' + FONT_FAMILY;
            ctx.fillText('Season start', x0 + 3, top + 12);
          }
          ctx.restore();
        });
      }
    };

    /* ── Panel A — Volume chart ──────────────────────────────────────── */
    var ctxVol = document.getElementById('chart-volume');
    if (!ctxVol) return;

    /* Build all labels (x-axis) from NZ source — widest date range. */
    var volLabels = (NZ.monthly_dried_eq_kg || []).map(function (p) { return p.x; });

    function buildVolDatasets(showNz, showQia, showKstat) {
      var ds = [];
      if (showNz) {
        ds.push({
          type: 'bar',
          label: 'NZ exports — monthly kg',
          data: xyFrom(NZ.monthly_dried_eq_kg),
          backgroundColor: 'rgba(26, 82, 118, 0.75)',
          borderColor: C_NZ,
          borderWidth: 1,
          barPercentage: 0.8,
          categoryPercentage: 0.9,
          yAxisID: 'y',
          order: 2
        });
        ds.push({
          type: 'line',
          label: 'NZ exports — rolling 12-month',
          data: xyFrom(NZ.rolling_12m_dried_eq_kg),
          borderColor: C_NZ,
          backgroundColor: 'transparent',
          borderWidth: 2,
          borderDash: [],
          pointStyle: 'circle',
          pointRadius: 3,
          tension: 0.3,
          yAxisID: 'y',
          order: 1
        });
      }
      if (showQia) {
        ds.push({
          type: 'bar',
          label: 'Korea quarantine (QIA) — monthly kg',
          data: xyFrom(QIA.monthly_dried_eq_kg),
          backgroundColor: 'rgba(125, 102, 8, 0.75)',
          borderColor: C_QIA,
          borderWidth: 1,
          barPercentage: 0.8,
          categoryPercentage: 0.9,
          yAxisID: 'y',
          order: 2
        });
        ds.push({
          type: 'line',
          label: 'Korea quarantine (QIA) — rolling 12-month',
          data: xyFrom(QIA.rolling_12m_dried_eq_kg),
          borderColor: C_QIA,
          backgroundColor: 'transparent',
          borderWidth: 2,
          borderDash: [6, 3],
          pointStyle: 'rectRot',
          pointRadius: 3,
          tension: 0.3,
          yAxisID: 'y',
          order: 1
        });
      }
      if (showKstat) {
        ds.push({
          type: 'bar',
          label: 'Korea customs (KSTAT) — monthly kg',
          data: xyFrom(KSTAT.monthly_dried_eq_kg),
          backgroundColor: 'rgba(110, 47, 10, 0.75)',
          borderColor: C_KSTAT,
          borderWidth: 1,
          barPercentage: 0.8,
          categoryPercentage: 0.9,
          yAxisID: 'y',
          order: 2
        });
        ds.push({
          type: 'line',
          label: 'Korea customs (KSTAT) — rolling 12-month',
          data: xyFrom(KSTAT.rolling_12m_dried_eq_kg),
          borderColor: C_KSTAT,
          backgroundColor: 'transparent',
          borderWidth: 2,
          borderDash: [2, 4],
          pointStyle: 'triangle',
          pointRadius: 3,
          tension: 0.3,
          yAxisID: 'y',
          order: 1
        });
      }
      return ds;
    }

    var volChart = new Chart(ctxVol.getContext('2d'), {
      type: 'bar',
      plugins: [harvestPlugin],
      data: {
        labels: volLabels,
        datasets: buildVolDatasets(true, true, true)
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        interaction: { mode: 'index', intersect: false },
        plugins: {
          legend: {
            position: 'top',
            align: 'start',
            labels: { boxWidth: 12, padding: 14 }
          },
          tooltip: {
            callbacks: {
              label: function (ctx) {
                return ctx.dataset.label + ': ' + Math.round(ctx.parsed.y).toLocaleString() + ' kg';
              }
            }
          }
        },
        scales: {
          x: {
            type: 'category',
            ticks: { maxTicksLimit: 8, maxRotation: 45 },
            grid: { color: 'rgba(204,204,204,0.4)' }
          },
          y: {
            beginAtZero: true,
            title: { display: true, text: 'Dried-equivalent kg' },
            ticks: { callback: function (v) { return v.toLocaleString(); } },
            grid: { color: 'rgba(204,204,204,0.4)' }
          }
        }
      }
    });

    /* Panel B (unit price chart) removed per Commander feedback F-06. */

    /* ── Panel C — Destination charts ───────────────────────────────── */
    /* C1: Stacked area — NZD FOB by destination, all available dates.  */
    /* C2: Pie — KG share by destination, latest full year.             */

    var DEST_AREA_DATA  = {{ tf_destination_area | tojson }};
    /* DEST_PIE_DATA removed per F-12 (pie chart removed). */
    var DEST_COLOURS = {
      'China':      '#A78230',
      'Korea':      '#1A5276',
      'Hong Kong':  '#7D6608',
      'Other':      '#9E9E9E'
    };
    var DEST_ORDER = ['China', 'Korea', 'Hong Kong', 'Other'];

    /* Build sorted label array from all dates across all destinations */
    (function buildDestCharts() {
      var ctxArea = document.getElementById('chart-destination-area');
      if (!ctxArea) return;

      /* Collect all unique dates across all destination series */
      var dateSet = {};
      DEST_ORDER.forEach(function (c) {
        var series = DEST_AREA_DATA[c] || [];
        series.forEach(function (pt) { dateSet[pt.x] = true; });
      });
      var areaLabels = Object.keys(dateSet).sort();
      if (!areaLabels.length) return;

      /* Build a lookup for each country: date -> value */
      function buildDataset(country) {
        var lookup = {};
        (DEST_AREA_DATA[country] || []).forEach(function (pt) { lookup[pt.x] = pt.y; });
        return areaLabels.map(function (d) { return lookup[d] || 0; });
      }

      var hexToRgba = function (hex, alpha) {
        var r = parseInt(hex.slice(1, 3), 16);
        var g = parseInt(hex.slice(3, 5), 16);
        var b = parseInt(hex.slice(5, 7), 16);
        return 'rgba(' + r + ',' + g + ',' + b + ',' + alpha + ')';
      };

      var areaDsets = DEST_ORDER.map(function (country) {
        return {
          label: country,
          data: buildDataset(country),
          backgroundColor: hexToRgba(DEST_COLOURS[country], 0.65),
          borderColor: DEST_COLOURS[country],
          borderWidth: 1.5,
          fill: true,
          tension: 0.2,
          pointRadius: 0,
          pointHoverRadius: 4
        };
      });

      new Chart(ctxArea.getContext('2d'), {
        type: 'line',
        data: { labels: areaLabels, datasets: areaDsets },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          interaction: { mode: 'index', intersect: false },
          plugins: {
            legend: {
              position: 'top',
              align: 'start',
              labels: { boxWidth: 12, padding: 14 }
            },
            tooltip: {
              callbacks: {
                label: function (ctx) {
                  return ctx.dataset.label + ': NZD ' + Math.round(ctx.parsed.y).toLocaleString();
                }
              }
            }
          },
          scales: {
            x: {
              type: 'category',
              ticks: { maxTicksLimit: 10, maxRotation: 45 },
              grid: { color: 'rgba(204,204,204,0.4)' }
            },
            y: {
              beginAtZero: true,
              stacked: true,
              title: { display: true, text: 'FOB value (NZD)' },
              ticks: { callback: function (v) { return v.toLocaleString(); } },
              grid: { color: 'rgba(204,204,204,0.4)' }
            }
          }
        }
      });

      /* C2 (pie chart) removed per Commander feedback F-12. */
    }());

    /* ── Panel D — QIA imports by origin ────────────────────────────── */
    /* Graceful skip if QIA data is empty (placeholder card shown in HTML) */
    (function buildQiaChart() {
      var ctxQia = document.getElementById('chart-qia-origin');
      if (!ctxQia) return;

      var QIA_DATA = {{ tf_qia_by_origin | tojson }};
      if (!QIA_DATA || !QIA_DATA.length) return;

      var QIA_COLOURS = {
        'New Zealand':     '#1A5276',
        'China':           '#A78230',
        'Russia':          '#888888',
        'Hong Kong (SAR)': '#7D6608',
        'Kazakhstan':      '#E8A87C',
        'Australia':       '#2C3E50',
        'Other':           '#BDBDBD'
      };

      /* Build the set of all countries that appear across both years */
      var allCountries = {};
      QIA_DATA.forEach(function (yr) {
        Object.keys(yr.countries).forEach(function (c) { allCountries[c] = true; });
      });
      /* Sort: named countries first in preferred order, then alphabetically */
      var preferred = ['New Zealand','China','Russia','Hong Kong (SAR)','Kazakhstan','Australia','Other'];
      var countryList = preferred.filter(function (c) { return allCountries[c]; });
      Object.keys(allCountries).forEach(function (c) {
        if (countryList.indexOf(c) < 0) countryList.push(c);
      });

      /* One dataset per country across years */
      var yearLabels = QIA_DATA.map(function (d) { return String(d.year); });

      var qiaDsets = countryList.map(function (country) {
        return {
          label: country,
          data: QIA_DATA.map(function (yr) { return yr.countries[country] || 0; }),
          backgroundColor: QIA_COLOURS[country] || '#BDBDBD',
          borderColor: QIA_COLOURS[country] || '#BDBDBD',
          borderWidth: 1
        };
      });

      new Chart(ctxQia.getContext('2d'), {
        type: 'bar',
        data: { labels: yearLabels, datasets: qiaDsets },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          interaction: { mode: 'index', intersect: false },
          plugins: {
            legend: {
              position: 'top',
              align: 'start',
              labels: { boxWidth: 12, padding: 14 }
            },
            tooltip: {
              callbacks: {
                label: function (ctx) {
                  return ctx.dataset.label + ': ' + Math.round(ctx.parsed.y).toLocaleString() + ' kg';
                }
              }
            }
          },
          scales: {
            x: {
              type: 'category',
              grid: { color: 'rgba(204,204,204,0.4)' }
            },
            y: {
              beginAtZero: true,
              stacked: true,
              title: { display: true, text: 'Import weight (kg)' },
              ticks: { callback: function (v) { return v.toLocaleString(); } },
              grid: { color: 'rgba(204,204,204,0.4)' }
            }
          }
        }
      });
    }());

    /* ── Source toggle handler ───────────────────────────────────────── */
    function getChecked() {
      return {
        nz:    document.getElementById('toggle-nz')    ? document.getElementById('toggle-nz').checked    : true,
        qia:   document.getElementById('toggle-qia')   ? document.getElementById('toggle-qia').checked   : true,
        kstat: document.getElementById('toggle-kstat') ? document.getElementById('toggle-kstat').checked : true
      };
    }

    document.querySelectorAll('.source-toggle input[type="checkbox"]').forEach(function (cb) {
      cb.addEventListener('change', function () {
        var sel = getChecked();

        /* Rebuild Panel A datasets */
        volChart.data.datasets = buildVolDatasets(sel.nz, sel.qia, sel.kstat);
        volChart.update();

        /* Panel B (unit price) removed per F-06 — no price chart to update. */
      });
    });

  }());
  </script>
  {% endif %}

  {# ── MFDS annual statistics chart — rendered when VFI_Price_Annual has data #}
  {# A-4/D-7: series label = "Korean herbal medicine channel (MFDS annual statistics)" #}
  {# D-10: bar colour = rgba(26,82,118,0.75) (dark blue, not gold)                     #}
  <script>
  (function () {
    var priceSeriesData = {{ price_annual_series | tojson }};
    if (!priceSeriesData || !priceSeriesData.length) return;
    var canvas = document.getElementById('b7PriceChart');
    if (!canvas) return;

    /* A-4: Override series label per CDR Decision 5. */
    /* If priceSeriesData has entries, relabel the first (primary) series. */
    if (priceSeriesData.length > 0) {
      priceSeriesData[0].label = 'Korean herbal medicine channel (MFDS annual statistics)';
      priceSeriesData[0].borderColor = '#1A5276';
      priceSeriesData[0].backgroundColor = 'rgba(26, 82, 118, 0.75)';
    }

    /* Build year labels from the first series data points. */
    var yearLabels = (priceSeriesData[0].data || []).map(function (pt) {
      return String(pt.x);
    });

    /* Convert {x, y} data to flat arrays aligned to yearLabels. */
    var datasets = priceSeriesData.map(function (ds) {
      var lookup = {};
      (ds.data || []).forEach(function (pt) { lookup[String(pt.x)] = pt.y; });
      return Object.assign({}, ds, {
        data: yearLabels.map(function (yr) { return lookup[yr] || 0; })
      });
    });

    new Chart(canvas.getContext('2d'), {
      type: 'bar',
      data: { labels: yearLabels, datasets: datasets },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: {
            display: true,
            position: 'top',
            align: 'start',
            labels: { boxWidth: 12, padding: 14 }
          },
          tooltip: {
            callbacks: {
              label: function (ctx) {
                return 'Korean herbal medicine channel — USD ' + ctx.parsed.y.toLocaleString() + ' thousands';
              }
            }
          }
        },
        scales: {
          x: {
            type: 'category',
            title: { display: true, text: 'Year' },
            ticks: { maxTicksLimit: 11 },
            grid: { color: 'rgba(204,204,204,0.4)' }
          },
          y: {
            beginAtZero: true,
            title: { display: true, text: 'USD thousands' },
            ticks: { callback: function (v) { return v.toLocaleString(); } },
            grid: { color: 'rgba(204,204,204,0.4)' }
          }
        }
      }
    });
  }());
  </script>

  {# ── SECTION: IMPORT INTELLIGENCE — C-4e redesign ─────────────────── #}
  {# F-17: all Korean text removed. F-16: 3-row default + "Show last 30 days". #}
  {# F-18: new column order with exporter. B-9/B-14: accordion added.         #}
  {% set import_intelligence = sections.import_intelligence if sections is defined and sections.import_intelligence is defined else {} %}
  <section id="import-intelligence">

    <div class="section-header">
      <div class="section-header-left">
        <h2>Import intelligence</h2>
        <span class="last-updated">Last updated: {{ import_intelligence.last_updated | default("—") }}</span>
      </div>
      {% if import_records_has_data or price_annual_has_data %}
        <a class="download-btn" href="downloads/import_intelligence.csv">Download CSV</a>
      {% endif %}
    </div>

    <p class="source-footnote">Korea deer velvet import data drawn from two MFDS (Ministry of Food and Drug Safety, Korea) sources: annual herbal medicine channel statistics and food ingredient import notifications. See table footnote for full attribution.</p>

    {# ── MFDS annual statistics chart / price placeholder ──────────────── #}
    {# D-2: compact placeholder card when no data. D-6: scope note above canvas. #}
    {% if price_annual_has_data %}
      <div class="chart-panel" id="b7-price-chart">
        <h3>Annual import value — Korean herbal medicine channel (MFDS statistics)</h3>
        <p class="chart-scope-note">Herbal medicine channel only — does not include food ingredient imports shown in the table below.</p>
        {% if price_annual_subtitle %}
          <p class="chart-subtitle">Latest ranked price: KRW {{ price_annual_subtitle.price_krw }} ({{ price_annual_subtitle.year }})</p>
        {% endif %}
        <div class="chart-canvas-wrapper" style="height:280px;">
          <canvas id="b7PriceChart" aria-label="Annual import value, Korean herbal medicine channel, MFDS statistics 2004 to 2024"></canvas>
        </div>
        <p class="chart-annotation">Source: MFDS (Ministry of Food and Drug Safety, Korea) annual statistics yearbook, Table 6-3-8. Korean herbal medicine channel only. Covers 2004–2024. Does not include food ingredient imports.</p>
      </div>
    {% else %}
      <div class="price-placeholder">Annual price data will appear here once available.</div>
    {% endif %}

    {# ── Import records table (independent degradation) ─────────────────── #}
    {% if import_records_has_data %}
      <h3 style="margin-top:32px;">Import records</h3>
      <p class="source-footnote">MFDS-registered deer velvet food-channel import notifications.</p>

      <div class="table-scroll-wrapper" id="import-table-wrapper">
        <table class="import-records-table" id="import-records-table">
          <caption>Korea deer velvet food import notifications</caption>
          <thead>
            <tr>
              <th scope="col">Date</th>
              <th scope="col">Country of origin</th>
              <th scope="col">Export country</th>
              <th scope="col">Exporter</th>
              <th scope="col">Importer</th>
              <th scope="col">Product name</th>
              <th scope="col">Type</th>
            </tr>
          </thead>
          <tbody id="import-records-tbody">
            {% for row in import_records_display %}
              <tr class="import-row{% if row._in_last_30d %} row-30d{% endif %}"
                  data-date="{{ row._display_date }}"
                  style="{% if not loop.first and loop.index > 3 %}display:none{% endif %}">
                <td class="data">{{ row._display_date }}</td>
                <td>{{ row._display_origin }}</td>
                <td>{{ row._display_export_country }}</td>
                <td>{{ row._display_exporter }}</td>
                <td>{{ row._display_importer }}</td>
                <td>{{ row._display_product }}</td>
                <td>{{ row._display_type }}</td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>

      <div class="table-controls">
        <button class="show-more-btn" id="show-more-btn" type="button"
                onclick="toggleImportRows(this)">Show last 30 days</button>
        <a class="download-btn" href="downloads/import_intelligence.csv">Download CSV</a>
      </div>

      <p class="table-footnote">Source: Korea Ministry of Food and Drug Safety import notification database. Importer names translated from Korean using curated lookup; exporter names appear as recorded in MFDS source data.</p>

    {% else %}
      <div class="placeholder-card" style="margin-top:32px;">
        <p class="placeholder-title">No import records available</p>
        <p class="placeholder-body">Data will appear here once the MFDS import records tab is populated.</p>
      </div>
    {% endif %}

    {# ── F-14 accordion — channel scope explanation ───────────────────── #}
    <details class="discrepancy-accordion" style="margin-top:20px;">
      <summary class="discrepancy-accordion__trigger" aria-label="Why do different sources show different import volumes?">
        <span>ⓘ Why do different sources show different import volumes?</span>
        <span class="discrepancy-accordion__chevron" aria-hidden="true">&#9654;</span>
      </summary>
      <div class="discrepancy-accordion__body">
        <h4>Why the chart and table show different figures</h4>
        <p>Two separate Korean government data sources appear in this section. They cover different import channels — the numbers are not directly comparable, and neither is wrong.</p>
        <p><strong>The chart</strong> (MFDS annual statistics) records deer velvet imported into Korea as a <em>herbal medicine or pharmaceutical ingredient</em>. This is a distinct regulatory channel governed by Korea's pharmaceutical authority. Figures show total annual value in USD, 2004–2024.</p>
        <p><strong>The records table</strong> (MFDS food import notifications) records deer velvet imported as a <em>food ingredient</em>. These are individual shipment notifications filed under Korea's food safety system, 2016–2026.</p>
        <p><strong>Two further points to note:</strong></p>
        <ul style="padding-left:20px;margin-top:6px;">
          <li style="margin-bottom:6px;">A third channel exists — sliced velvet imported as a food supplement under a separate product classification — which neither source covers. Total Korean deer velvet imports are therefore higher than either source shows alone.</li>
          <li>NZ supplied 66% of Korea's herbal medicine channel imports by value in 2024 (USD 18.5 million of USD 28.0 million total).</li>
        </ul>
      </div>
    </details>

  </section>

  {# ── Import records JS — show/hide rows (client-side, no rebuild) ──── #}
  <script>
  (function () {
    var CUTOFF = '{{ cutoff_30d }}';

    function toggleImportRows(btn) {
      var tbody = document.getElementById('import-records-tbody');
      if (!tbody) return;
      var rows = tbody.querySelectorAll('tr.import-row');
      var expanded = btn.getAttribute('data-expanded') === 'true';

      if (!expanded) {
        /* Expand: show rows within last 30 days */
        var shown = 0;
        rows.forEach(function (row) {
          var rowDate = row.getAttribute('data-date') || '';
          if (rowDate >= CUTOFF) {
            row.style.display = '';
            shown++;
          }
        });
        /* If no rows matched, show first 10 as fallback */
        if (shown === 0) {
          var fallback = 0;
          rows.forEach(function (row) {
            if (fallback < 10) { row.style.display = ''; fallback++; }
          });
        }
        btn.textContent = 'Show fewer';
        btn.setAttribute('data-expanded', 'true');
        /* Scroll hint */
        checkOverflow();
      } else {
        /* Collapse: show only first 3 rows */
        rows.forEach(function (row, idx) {
          row.style.display = idx < 3 ? '' : 'none';
        });
        btn.textContent = 'Show last 30 days';
        btn.setAttribute('data-expanded', 'false');
      }
    }

    /* Expose for inline onclick */
    window.toggleImportRows = toggleImportRows;

    /* Scroll hint: add .is-overflowing if table wider than wrapper */
    function checkOverflow() {
      var wrapper = document.getElementById('import-table-wrapper');
      if (!wrapper) return;
      var table = wrapper.querySelector('table');
      if (!table) return;
      if (table.scrollWidth > wrapper.clientWidth) {
        wrapper.classList.add('is-overflowing');
      } else {
        wrapper.classList.remove('is-overflowing');
      }
    }

    window.addEventListener('resize', checkOverflow);
    checkOverflow();
  }());
  </script>

  {# ── SECTION: MARKET PRESENCE (enabled: false — hardcoded placeholder) #}
  {# No download button. No last-updated label. Static "coming next phase" card. #}
  <section id="market-presence">

    <div class="section-header">
      <div class="section-header-left">
        <h2>Market presence</h2>
        <span class="last-updated last-updated--deferred">Coming next phase</span>
      </div>
      {# No download button — no data in Phase 1 #}
    </div>

    <div class="placeholder-card">
      <p class="placeholder-title">Market presence — coming in the next phase</p>
      <p class="placeholder-body">Product registry data from Korean retail and food-service channels will appear here. This section will show brand presence, product formats, and retail distribution across the Korea market.</p>
    </div>

  </section>

  {# ── SECTION: NEWS PULSE ──────────────────────────────────────────── #}
  {# Data source: KVN_Articles tab. Column schema (from classify_articles.py): #}
  {#   content_hash | url | title_ko | description | published_date |          #}
  {#   source_name | source_type | keyword_matched | category |                #}
  {#   english_summary | ai_processed_at | include_on_site                     #}
  {# Only rows where include_on_site is "TRUE" AND published_date >= cutoff_90d #}
  {# appear in the article list (C-5e: 90-day window applied at render time).  #}
  {% set news_pulse = sections.news_pulse if sections is defined and sections.news_pulse is defined else {} %}
  <section id="news-pulse">

    <div class="section-header">
      <div class="section-header-left">
        <h2>News pulse</h2>
        <span class="last-updated">Last updated: {{ news_pulse.last_updated | default("—") }}</span>
      </div>
      {% if news_pulse.enabled and news_pulse.has_data %}
        <a class="download-btn" href="downloads/news_pulse.csv">Download CSV</a>
      {% endif %}
    </div>

    {# D-17 / T-27: framing line above article list — scope context before content #}
    <p class="source-footnote">Korea deer velvet news — Naver and Google News, classified and summarised by AI. Showing relevant articles from the last 90 days.</p>

    {% if news_pulse.enabled and news_pulse.has_data %}

      {# C-5e D-14: filter to include_on_site == "TRUE" AND published_date >= cutoff_90d #}
      {# cutoff_90d is injected by build.py as an ISO date string (YYYY-MM-DD).          #}
      {% set publishable = [] %}
      {% for row in news_pulse.data %}
        {% if row.include_on_site | string | upper in ("TRUE", "1", "YES") and row.published_date | string >= cutoff_90d %}
          {% set _ = publishable.append(row) %}
        {% endif %}
      {% endfor %}

      {% if publishable %}
        {# D-18: count + period label above the article list #}
        <p class="article-list-header">{{ publishable | length }} relevant article{{ 's' if publishable | length != 1 else '' }} — last 90 days</p>
        <ul class="article-list" aria-label="Korea deer velvet relevant articles — last 90 days">
          {% for article in publishable %}
            <li class="article-entry">
              <div class="article-body">
                {# C-6a: live KVN_Articles sheet column swap — 'title' col holds the URL; 'url' col holds the Korean title text (confirmed C-5h). Use article.title for href, article.url for display text. #}
                <a class="article-title" href="{{ article.title | default('#') }}" target="_blank" rel="noopener noreferrer">{{ article.url | default("") }}</a>
                <p class="article-summary">{{ article.english_summary | default("") }}</p>
              </div>
              <div class="article-meta">
                <span class="article-meta-date">{{ article.published_date | default("") }}</span>
                {% if article.category %}
                  <span class="article-meta-category">{{ article.category }}</span>
                {% endif %}
              </div>
            </li>
          {% endfor %}
        </ul>
      {% else %}
        {# D-15 State A: data exists but 90-day count = 0 — quiet period, pipeline healthy #}
        <div class="placeholder-card">
          <p class="placeholder-title">No relevant articles in the last 90 days.</p>
          <p class="placeholder-body">Korea deer velvet news is monitored three times per week via Naver and Google News.</p>
        </div>
      {% endif %}

      {# D-13 / T-35: attribution footnote — both Google News and Naver named #}
      <p class="source-footnote">Sources: Naver News API · Google News — Korean-language deer velvet news, classified and summarised by AI (Claude Haiku).</p>

    {% else %}
      {# D-15 State B: section not enabled or no data rows at all — graceful degradation (L-12) #}
      <div class="placeholder-card">
        <p class="placeholder-title">News collection is in progress.</p>
        <p class="placeholder-body">Articles will appear after the next scheduled update.</p>
      </div>
      {# D-13 / T-35: attribution footnote — both branches #}
      <p class="source-footnote">Sources: Naver News API · Google News — Korean-language deer velvet news, classified and summarised by AI (Claude Haiku).</p>
    {% endif %}

  </section>

</main>

