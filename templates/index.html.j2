{# ── CHART.JS ─────────────────────────────────────────────────────────── #}
<script src="assets/chart.min.js"></script>

{# ── A1/A2 TOGGLE CHARTS ─────────────────────────────────────────────── #}
{% if sections is defined and sections.trade_flows is defined and sections.trade_flows.enabled and sections.trade_flows.has_data %}
<script>
(function () {
  'use strict';

  /* ── Raw row data injected by build.py ──────────────────────────────── */
  var QIA_ROWS = {{ qia_raw_rows | tojson }};
  var NZ_ROWS  = {{ nz_raw_rows  | tojson }};

  /* Korean country name → English mapping for QIA rows */
  var QIA_COUNTRY_MAP = {
    '뉴질랜드': 'New Zealand',  /* 뉴질랜드 */
    '중국':             'China',          /* 중국 */
    '러시아':       'Russia',         /* 러시아 */
    '홍콩':             'Hong Kong',      /* 홍콩 */
    '카자흐스탄': 'Kazakhstan', /* 카자흐스탄 */
    '호주':             'Australia',      /* 호주 */
    '몽골':             'Mongolia',       /* 몽골 */
    '미국':             'United States',  /* 미국 */
    '싱가포르':     'Singapore'       /* 싱가포르 */
  };

  /* ── Chart.js shared defaults ─────────────────────────────────────── */
  var FONT = '"Trebuchet MS", "Gill Sans MT", Arial, sans-serif';
  Chart.defaults.font.family = FONT;
  Chart.defaults.font.size   = 11;
  Chart.defaults.color       = '#444444';

  /* ── Colour palette (from spec §4) ──────────────────────────────────── */
  var C_FRESH  = { fill: 'rgba(26, 82, 118, 0.75)',   border: '#1A5276' };
  var C_DRIED  = { fill: 'rgba(125, 102, 8, 0.75)',   border: '#7D6608' };
  var C_OTHER  = { fill: 'rgba(110, 47, 10, 0.75)',   border: '#6E2F0A' };
  var C_LINE   = '#000000';

  /* ── State for each chart ────────────────────────────────────────────── */
  var a1State = { view: 'monthly', from: '', to: '', country: '', form: '' };
  var a2State = { view: 'monthly', from: '', to: '', country: '', form: '' };

  /* ── Helper: last 12 months as YYYY-MM strings ───────────────────────── */
  function last12Months() {
    var now = new Date();
    var end = now.getFullYear() + '-' + String(now.getMonth() + 1).padStart(2, '0');
    var d = new Date(now.getFullYear(), now.getMonth() - 11, 1);
    var start = d.getFullYear() + '-' + String(d.getMonth() + 1).padStart(2, '0');
    return { start: start, end: end };
  }

  /* ── Populate country dropdowns from raw data ─────────────────────── */
  function populateCountries(rows, selectId, countryMapFn) {
    var seen = {};
    rows.forEach(function (r) {
      var en = countryMapFn(r.country);
      if (en && !seen[en]) { seen[en] = true; }
    });
    var sel = document.getElementById(selectId);
    if (!sel) return;
    Object.keys(seen).sort().forEach(function (name) {
      var opt = document.createElement('option');
      opt.value = name;
      opt.textContent = name;
      sel.appendChild(opt);
    });
  }

  /* QIA: map Korean → English (unknown kept as-is) */
  function qiaCountryEn(raw) {
    return QIA_COUNTRY_MAP[raw] || raw;
  }

  /* NZ: already English */
  function nzCountryEn(raw) { return raw; }

  /* ── Filter raw rows ─────────────────────────────────────────────────── */
  function filterRows(rows, state, countryMapFn) {
    return rows.filter(function (r) {
      var date = r.date; /* YYYY-MM */
      if (state.from && date < state.from) return false;
      if (state.to   && date > state.to)   return false;
      if (state.country) {
        var en = countryMapFn(r.country);
        if (en !== state.country) return false;
      }
      if (state.form) {
        if (r.product_type !== state.form) return false;
      }
      return true;
    });
  }

  /* ── Aggregate filtered rows by month ────────────────────────────────── */
  /* Frozen equivalent: dried ÷ 0.33 (spec §1 A1 Unit note) */
  function toFrozenEq(value, productType) {
    if (productType === 'dried') return value / 0.33;
    return value; /* frozen already in frozen units; other passes through */
  }

  function aggregateByMonth(rows, countryMapFn) {
    /* Returns { date: { fresh: kg, dried: kg, other: kg } } */
    var totals = {};
    rows.forEach(function (r) {
      var d = r.date;
      if (!totals[d]) totals[d] = { fresh: 0, dried: 0, other: 0 };
      var frozenEq = toFrozenEq(r.value, r.product_type);
      if (r.product_type === 'frozen') {
        totals[d].fresh += frozenEq;
      } else if (r.product_type === 'dried') {
        totals[d].dried += frozenEq;
      } else {
        totals[d].other += frozenEq;
      }
    });
    return totals;
  }

  function aggregateByYear(rows, countryMapFn) {
    /* Returns { year: { fresh: kg, dried: kg, other: kg } } */
    var totals = {};
    rows.forEach(function (r) {
      var yr = r.date.slice(0, 4);
      if (!totals[yr]) totals[yr] = { fresh: 0, dried: 0, other: 0 };
      var frozenEq = toFrozenEq(r.value, r.product_type);
      if (r.product_type === 'frozen') {
        totals[yr].fresh += frozenEq;
      } else if (r.product_type === 'dried') {
        totals[yr].dried += frozenEq;
      } else {
        totals[yr].other += frozenEq;
      }
    });
    return totals;
  }

  /* ── Rolling 12-month total from monthly totals ────────────────────── */
  function computeRolling12m(monthlyTotals, sortedLabels) {
    return sortedLabels.map(function (d, i) {
      var window = sortedLabels.slice(Math.max(0, i - 11), i + 1);
      return window.reduce(function (sum, w) {
        var t = monthlyTotals[w] || { fresh: 0, dried: 0, other: 0 };
        return sum + t.fresh + t.dried + t.other;
      }, 0);
    });
  }

  /* ── Format month label ─────────────────────────────────────────────── */
  var MONTH_ABBR = ['', 'Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun',
                    'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];

  function formatMonthLabel(yyyymm) {
    var yr = yyyymm.slice(0, 4);
    var mo = parseInt(yyyymm.slice(5, 7), 10);
    return MONTH_ABBR[mo] + ' ' + yr;
  }

  /* ── Build Chart.js datasets ─────────────────────────────────────────── */
  function buildMonthlyDatasets(monthlyTotals, sortedLabels) {
    var freshData  = sortedLabels.map(function (d) { return Math.round((monthlyTotals[d] || {}).fresh || 0); });
    var driedData  = sortedLabels.map(function (d) { return Math.round((monthlyTotals[d] || {}).dried || 0); });
    var otherData  = sortedLabels.map(function (d) { return Math.round((monthlyTotals[d] || {}).other || 0); });
    var rolling    = computeRolling12m(monthlyTotals, sortedLabels);

    /* Only include segments that have non-zero data */
    var ds = [];
    if (freshData.some(function (v) { return v > 0; })) {
      ds.push({ type: 'bar', label: 'Fresh velvet', data: freshData,
                backgroundColor: C_FRESH.fill, borderColor: C_FRESH.border,
                borderWidth: 1, stack: 'forms', order: 2 });
    }
    if (driedData.some(function (v) { return v > 0; })) {
      ds.push({ type: 'bar', label: 'Dried velvet', data: driedData,
                backgroundColor: C_DRIED.fill, borderColor: C_DRIED.border,
                borderWidth: 1, stack: 'forms', order: 2 });
    }
    if (otherData.some(function (v) { return v > 0; })) {
      ds.push({ type: 'bar', label: 'Other', data: otherData,
                backgroundColor: C_OTHER.fill, borderColor: C_OTHER.border,
                borderWidth: 1, stack: 'forms', order: 2 });
    }
    ds.push({ type: 'line', label: 'Trailing 12 months', data: rolling,
              borderColor: C_LINE, backgroundColor: 'transparent',
              borderWidth: 2, pointStyle: 'none', tension: 0.3, order: 1 });
    return ds;
  }

  function buildAnnualDatasets(annualTotals, sortedLabels) {
    var freshData  = sortedLabels.map(function (yr) { return Math.round((annualTotals[yr] || {}).fresh || 0); });
    var driedData  = sortedLabels.map(function (yr) { return Math.round((annualTotals[yr] || {}).dried || 0); });
    var otherData  = sortedLabels.map(function (yr) { return Math.round((annualTotals[yr] || {}).other || 0); });

    var ds = [];
    if (freshData.some(function (v) { return v > 0; })) {
      ds.push({ type: 'bar', label: 'Fresh velvet', data: freshData,
                backgroundColor: C_FRESH.fill, borderColor: C_FRESH.border,
                borderWidth: 1, stack: 'forms' });
    }
    if (driedData.some(function (v) { return v > 0; })) {
      ds.push({ type: 'bar', label: 'Dried velvet', data: driedData,
                backgroundColor: C_DRIED.fill, borderColor: C_DRIED.border,
                borderWidth: 1, stack: 'forms' });
    }
    if (otherData.some(function (v) { return v > 0; })) {
      ds.push({ type: 'bar', label: 'Other', data: otherData,
                backgroundColor: C_OTHER.fill, borderColor: C_OTHER.border,
                borderWidth: 1, stack: 'forms' });
    }
    /* No rolling line in annual view */
    return ds;
  }

  /* ── Chart config factory ────────────────────────────────────────────── */
  function makeChartConfig(labels, datasets, isAnnual) {
    return {
      type: 'bar',
      data: { labels: labels, datasets: datasets },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        interaction: { mode: 'index', intersect: false },
        plugins: {
          legend: { position: 'top', align: 'start', labels: { boxWidth: 12, padding: 14 } },
          tooltip: {
            callbacks: {
              label: function (ctx) {
                return ctx.dataset.label + ': ' + Math.round(ctx.parsed.y).toLocaleString() + ' kg';
              }
            }
          }
        },
        scales: {
          x: {
            type: 'category',
            stacked: true,
            ticks: { maxTicksLimit: 12, maxRotation: 45 },
            grid: { display: false }
          },
          y: {
            beginAtZero: true,
            stacked: true,
            title: { display: true, text: 'Frozen equivalent volume (kg)' },
            ticks: { callback: function (v) { return v.toLocaleString(); } },
            grid: { color: 'rgba(204,204,204,0.4)' }
          }
        }
      }
    };
  }

  /* ── Chart instances ─────────────────────────────────────────────────── */
  var a1Chart = null;
  var a2Chart = null;

  /* N2: T12M toggle handlers — hide/show the trailing-12-month line dataset */
  window.a1ToggleT12M = function (cb) {
    if (!window._a1Chart) return;
    var ds = window._a1Chart.data.datasets;
    var idx = ds.findIndex(function (d) { return d.label && d.label.indexOf('12') !== -1; });
    if (idx === -1) return;
    ds[idx].hidden = !cb.checked;
    window._a1Chart.update();
  };

  window.a2ToggleT12M = function (cb) {
    if (!window._a2Chart) return;
    var ds = window._a2Chart.data.datasets;
    var idx = ds.findIndex(function (d) { return d.label && d.label.indexOf('12') !== -1; });
    if (idx === -1) return;
    ds[idx].hidden = !cb.checked;
    window._a2Chart.update();
  };

  /* ── Render function for A1 ─────────────────────────────────────────── */
  function a1Render() {
    var isAnnual = a1State.view === 'annual';
    var filtered = filterRows(QIA_ROWS, a1State, qiaCountryEn);

    var labels, datasets;
    if (isAnnual) {
      var annual = aggregateByYear(filtered, qiaCountryEn);
      labels   = Object.keys(annual).sort();
      datasets = buildAnnualDatasets(annual, labels);
    } else {
      var monthly = aggregateByMonth(filtered, qiaCountryEn);
      var allLabels = Object.keys(monthly).sort();
      labels   = allLabels.map(formatMonthLabel);
      datasets = buildMonthlyDatasets(monthly, allLabels);
    }

    if (!a1Chart) {
      var ctx = document.getElementById('chart-a1');
      if (!ctx) return;
      a1Chart = new Chart(ctx.getContext('2d'), makeChartConfig(labels, datasets, isAnnual));
      window._a1Chart = a1Chart;  /* N2: expose for T12M toggle */
    } else {
      a1Chart.data.labels   = labels;
      a1Chart.data.datasets = datasets;
      a1Chart.options.scales.x.stacked = true;
      a1Chart.options.scales.y.stacked = !isAnnual;
      a1Chart.update();
    }
  }

  /* ── Render function for A2 ─────────────────────────────────────────── */
  function a2Render() {
    var isAnnual = a2State.view === 'annual';
    var filtered = filterRows(NZ_ROWS, a2State, nzCountryEn);

    var labels, datasets;
    if (isAnnual) {
      var annual = aggregateByYear(filtered, nzCountryEn);
      labels   = Object.keys(annual).sort();
      datasets = buildAnnualDatasets(annual, labels);
    } else {
      var monthly = aggregateByMonth(filtered, nzCountryEn);
      var allLabels = Object.keys(monthly).sort();
      labels   = allLabels.map(formatMonthLabel);
      datasets = buildMonthlyDatasets(monthly, allLabels);
    }

    if (!a2Chart) {
      var ctx = document.getElementById('chart-a2');
      if (!ctx) return;
      a2Chart = new Chart(ctx.getContext('2d'), makeChartConfig(labels, datasets, isAnnual));
      window._a2Chart = a2Chart;  /* N2: expose for T12M toggle */
    } else {
      a2Chart.data.labels   = labels;
      a2Chart.data.datasets = datasets;
      a2Chart.options.scales.y.stacked = !isAnnual;
      a2Chart.update();
    }
  }

  /* ── View toggle handlers ────────────────────────────────────────────── */
  window.a1SetView = function (view, btn) {
    a1State.view = view;
    document.querySelectorAll('#a1-seg button').forEach(function (b) {
      b.setAttribute('aria-pressed', b.dataset.view === view ? 'true' : 'false');
    });
    var sel = document.getElementById('a1-seg-select');
    if (sel) sel.value = view;
    a1Render();
  };

  window.a1SetViewFromSelect = function (sel) {
    a1State.view = sel.value;
    document.querySelectorAll('#a1-seg button').forEach(function (b) {
      b.setAttribute('aria-pressed', b.dataset.view === sel.value ? 'true' : 'false');
    });
    a1Render();
  };

  window.a2SetView = function (view, btn) {
    a2State.view = view;
    document.querySelectorAll('#a2-seg button').forEach(function (b) {
      b.setAttribute('aria-pressed', b.dataset.view === view ? 'true' : 'false');
    });
    var sel = document.getElementById('a2-seg-select');
    if (sel) sel.value = view;
    a2Render();
  };

  window.a2SetViewFromSelect = function (sel) {
    a2State.view = sel.value;
    document.querySelectorAll('#a2-seg button').forEach(function (b) {
      b.setAttribute('aria-pressed', b.dataset.view === sel.value ? 'true' : 'false');
    });
    a2Render();
  };

  window.a1Render = function () {
    var fromEl    = document.getElementById('a1-from');
    var toEl      = document.getElementById('a1-to');
    var countryEl = document.getElementById('a1-country');
    var formEl    = document.getElementById('a1-form');
    a1State.from    = fromEl    ? fromEl.value    : '';
    a1State.to      = toEl      ? toEl.value      : '';
    a1State.country = countryEl ? countryEl.value : '';
    a1State.form    = formEl    ? formEl.value    : '';
    a1Render();
  };

  window.a2Render = function () {
    var fromEl    = document.getElementById('a2-from');
    var toEl      = document.getElementById('a2-to');
    var countryEl = document.getElementById('a2-country');
    var formEl    = document.getElementById('a2-form');
    a2State.from    = fromEl    ? fromEl.value    : '';
    a2State.to      = toEl      ? toEl.value      : '';
    a2State.country = countryEl ? countryEl.value : '';
    a2State.form    = formEl    ? formEl.value    : '';
    a2Render();
  };

  /* ── Init: set defaults, populate dropdowns, render ─────────────────── */
  (function init() {
    var range = last12Months();

    /* Populate country dropdowns */
    populateCountries(QIA_ROWS, 'a1-country', qiaCountryEn);
    populateCountries(NZ_ROWS,  'a2-country', nzCountryEn);

    /* Set default date range to last 12 months */
    var a1From = document.getElementById('a1-from');
    var a1To   = document.getElementById('a1-to');
    if (a1From) a1From.value = range.start;
    if (a1To)   a1To.value   = range.end;
    a1State.from = a1From ? a1From.value : '';
    a1State.to   = a1To   ? a1To.value   : '';

    var a2From = document.getElementById('a2-from');
    var a2To   = document.getElementById('a2-to');
    if (a2From) a2From.value = range.start;
    if (a2To)   a2To.value   = range.end;
    a2State.from = a2From ? a2From.value : '';
    a2State.to   = a2To   ? a2To.value   : '';

    /* Initial render */
    a1Render();
    a2Render();
  }());

}());
</script>
{% endif %}

{# ── sticky nav active-section observer ──────────────────────────────── #}
<script>
(function () {
  'use strict';
  var sections = ['section-1', 'section-2', 'section-3', 'section-4', 'section-5'];
  var navLinks = {};
  sections.forEach(function (id) {
    var link = document.querySelector('nav.section-nav a[href="#' + id + '"]');
    if (link) navLinks[id] = link;
  });

  function setActive(id) {
    Object.keys(navLinks).forEach(function (k) {
      navLinks[k].classList.toggle('is-active', k === id);
    });
  }

  if ('IntersectionObserver' in window) {
    var observer = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          setActive(entry.target.id);
        }
      });
    }, { rootMargin: '-30% 0px -60% 0px' });

    sections.forEach(function (id) {
      var el = document.getElementById(id);
      if (el) observer.observe(el);
    });
  }
}());
</script>

{# ── A3 PRICE CHART (MFDS) ───────────────────────────────────────────── #}
{% if mfds_annual_series and mfds_annual_series.has_data %}
<script>
(function () {
  'use strict';
  var mfdsData = {{ mfds_annual_series.chart_points | tojson }};
  if (!mfdsData || !mfdsData.length) return;

  var canvas = document.getElementById('chart-a3');
  if (!canvas) return;

  var yearLabels = mfdsData.map(function (pt) { return String(pt.x); });
  var values     = mfdsData.map(function (pt) { return pt.y; });

  new Chart(canvas.getContext('2d'), {
    type: 'bar',
    data: {
      labels: yearLabels,
      datasets: [{
        data: values,
        backgroundColor: 'rgba(26, 82, 118, 0.75)',
        borderColor: '#1A5276',
        borderWidth: 1
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: { display: false },  /* single-series — no legend needed */
        tooltip: {
          callbacks: {
            label: function (ctx) {
              return 'USD ' + ctx.parsed.y.toLocaleString() + ' thousands';
            }
          }
        }
      },
      scales: {
        x: {
          type: 'category',
          ticks: { maxTicksLimit: 10 },
          grid: { display: false }
        },
        y: {
          beginAtZero: true,
          title: { display: true, text: 'Average import price (KRW/kg)' },
          ticks: { callback: function (v) { return v.toLocaleString(); } },
