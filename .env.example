# Copy this file to .env and fill in values. Never commit .env to git.
#
# GOOGLE_SERVICE_ACCOUNT_JSON: paste the entire service account key JSON
# on a single line (no line breaks). Multi-line JSON will cause JSONDecodeError.
# Minify command:
#   python -c "import json,sys; print(json.dumps(json.load(sys.stdin), separators=(',',':')))" < key.json
#
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project-id","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"your-sa@your-project.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"..."}

# VKH_SHEET_ID: the Google Sheet ID for VKH_Data.
# Obtain by running: PYTHONPATH=. python scripts/setup_sheets.py --sheet-id <ID>
# after Commander creates and shares the sheet (see setup_sheets.py instructions).
VKH_SHEET_ID=your_google_sheet_id_here

# ANTHROPIC_API_KEY: for the AI classification and translation pipeline (Phase B).
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ALERT_EMAIL: administrator email for build failure alerts.
ALERT_EMAIL=seouldesk.help@gmail.com
